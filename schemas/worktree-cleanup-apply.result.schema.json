{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sven1103-agent/opencode-worktree-plugin/schemas/worktree-cleanup-apply.result.schema.json",
  "title": "worktree_cleanup apply result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "mode",
    "default_branch",
    "base_branch",
    "base_ref",
    "requested_selectors",
    "removed",
    "failed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "ok": {
      "type": "boolean",
      "const": true
    },
    "mode": {
      "type": "string",
      "const": "apply"
    },
    "default_branch": {
      "type": "string",
      "minLength": 1
    },
    "base_branch": {
      "type": "string",
      "minLength": 1
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "requested_selectors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "removed": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/removedItem"
      }
    },
    "failed": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failedItem"
      }
    },
    "message": {
      "type": "string"
    }
  },
  "$defs": {
    "baseCleanupItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "worktree_path",
        "head",
        "status",
        "reason",
        "detached",
        "selectable"
      ],
      "properties": {
        "branch": {
          "type": ["string", "null"]
        },
        "worktree_path": {
          "type": ["string", "null"]
        },
        "head": {
          "type": ["string", "null"]
        },
        "status": {
          "type": ["string", "null"],
          "enum": ["safe", "review", "blocked", null]
        },
        "reason": {
          "type": ["string", "null"]
        },
        "detached": {
          "type": "boolean"
        },
        "selectable": {
          "type": ["boolean", "null"]
        }
      }
    },
    "removedItem": {
      "allOf": [
        {
          "$ref": "#/$defs/baseCleanupItem"
        },
        {
          "type": "object",
          "required": ["selected"],
          "properties": {
            "selected": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "failedItem": {
      "allOf": [
        {
          "$ref": "#/$defs/baseCleanupItem"
        },
        {
          "type": "object",
          "required": ["selector"],
          "properties": {
            "selector": {
              "type": ["string", "null"]
            }
          }
        }
      ]
    }
  }
}
